# Used by Next rewrites (server-side) and by production builds when the
# browser talks to a separate API host (Railway, etc.).
# Local browser traffic uses same-origin /backend → this target (no CORS).
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Optional override for the rewrite destination only (not exposed to browser).
# API_PROXY_TARGET=http://127.0.0.1:8000
