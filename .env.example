# Copy to .env for docker-compose, or set in Railway / Vercel dashboards.

# Backend (Railway)
W3W_API_KEY=
ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:3000
ALLOW_VERCEL_PREVIEWS=true
PORT=8000

# Frontend (Vercel) — must be set before build
NEXT_PUBLIC_API_URL=https://your-api.up.railway.app